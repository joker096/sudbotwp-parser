# Google Gemini API Key for spam detection
# Get one at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Check interval in ms (default: 600000 = 10 minutes)
CHECK_INTERVAL=600000

# Batch size for Gemini checks (default: 50)
BATCH_SIZE=50
